    },
    "qq": {
      "enabled": false,
      "botId": "",
      "token": ""
    },
    "wecom": {
      "enabled": false,
      "corpId": "",
      "agentId": "",
      "secret": ""
    }
  },
  "feishu": {
    "appId": "cli_xxx",
    "appSecret": "secret_xxx",
    "botName": "Claw Assistant",
