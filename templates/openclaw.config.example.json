{
  "openclaw": {
    "home": "/path/to/openclaw/home",
    "stateDir": "/path/to/openclaw/state",
    "configPath": "/path/to/openclaw/config.json"
  },
  "models": {
    "provider": "openai",
    "baseUrl": "https://api.example.com/v1",
    "apiKeyEnv": "OPENAI_API_KEY",
    "defaultModel": "gpt-5-mini",
    "dailyLimit": "10k",
    "list": [
      {
        "id": "gpt-5-mini",
        "name": "GPT-5 Mini",
        "contextWindow": 200000,
        "maxTokens": 8192,
        "reasoning": false
      }
    ]
  },
  "channels": {
